{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    {
      "source": "/landing-api/(.*)",
      "destination": "/landing-page/travel-landing-page/backend/index.js"
    },
    {
      "source": "/landing-page/(.*)",
      "destination": "/landing-page/travel-landing-page/dist/index.html"
    },
    {
      "source": "/booking/(.*)",
      "destination": "/booking-app/dist/index.html"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/dashboard/dist/index.html"
    },
    { "source": "/(.*)", "destination": "/my-app/dist/index.html" }
  ]
}
