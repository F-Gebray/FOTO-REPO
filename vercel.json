{
  "version": 2,
  "builds": [
    { "src": "booking-app/package.json", "use": "@vercel/static-build" },
    { "src": "api/portfolio-project/server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/portfolio-project/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "booking-app/dist/index.html" }
  ]
}
