{
  "version": 2,
  "builds": [
    {
      "src": "my-app/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/server.js" },
    { "src": "/assets/(.*)", "dest": "my-app/assets/$1" },
    { "src": "/favicon.svg", "dest": "my-app/favicon.svg" },
    { "src": "/icons.svg", "dest": "my-app/icons.svg" },
    { "handle": "filesystem" },
    {
      "src": "/.*",
      "dest": "my-app/index.html"
    }
  ]
}
